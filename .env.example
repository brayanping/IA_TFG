# ============================================
# CONFIGURACIÓN POR DEFECTO - Edu-IA Backend
# ============================================
# 
# INSTRUCCIONES:
# 1. Copiar este archivo como: .env
# 2. No modificar nada (valores por defecto ya están OK)
# 3. Guardar en la carpeta raíz del proyecto
#
# ============================================

# Base de Datos - DESARROLLO (H2 embebida)
# Cambiar a PostgreSQL en producción
SPRING_DATASOURCE_URL=jdbc:h2:mem:testdb
SPRING_DATASOURCE_DRIVER_CLASS_NAME=org.h2.Driver
SPRING_JPA_DATABASE_PLATFORM=org.hibernate.dialect.H2Dialect
SPRING_JPA_HIBERNATE_DDL_AUTO=create-drop

# Servidor
SERVER_PORT=8080
SERVER_SERVLET_CONTEXT_PATH=/api

# JWT - Tokens de autenticación
JWT_SECRET=tu_clave_secreta_super_segura_cambiar_en_produccion
JWT_EXPIRATION=86400000

# Servicio IA
IA_SERVICE_URL=http://localhost:8000
IA_SERVICE_TIMEOUT=30000

# CORS - Permitir frontend en localhost
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3001

# Logging
LOGGING_LEVEL_ROOT=INFO
LOGGING_LEVEL_COM_DAM_EDUIA=DEBUG

# Spring Boot
SPRING_APPLICATION_NAME=edu-ia-backend
